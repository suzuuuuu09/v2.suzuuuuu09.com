---
import { css, cx, cva } from "styled-system/css";
import { styled as s } from "styled-system/jsx";
import { categories } from "@/consts/category";

export interface Props {
	category?: string;
}

const { category } = Astro.props;

const currentCategory = categories.find((cat) => cat.category === category);

const badgeStyles = cva({
	variants: {
		category: {
			tech: {
				bg: "sz.primary/20",
				color: "sz.primary",
				borderColor: "sz.primary/40",
			},
			idea: {
				bg: "sz.secondary/25",
				color: "sz.text.main",
				borderColor: "sz.secondary/50",
			},
			work: {
				bg: "sz.purple/20",
				color: "sz.purple",
				borderColor: "sz.purple/40",
			},
			private: {
				bg: "sz.yellow/25",
				color: "sz.text.main",
				borderColor: "sz.yellow/50",
			},
		},
	},
	defaultVariants: {
		category: "tech",
	},
});
---

{
  currentCategory && (
    <s.div
      class={badgeStyles({ category: currentCategory.category })}
      display="inline-flex"
      alignItems="center"
      gap="1"
      px="2.5"
      py="1"
      borderRadius="md"
      fontSize="xs"
      fontWeight="semibold"
      borderWidth="1"
    >
      <s.span>{currentCategory.emoji}</s.span>
      <s.span textTransform="capitalize">{currentCategory.category}</s.span>
    </s.div>
  )
}

